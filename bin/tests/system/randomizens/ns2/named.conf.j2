options {
	query-source address 10.53.0.2;
	notify-source 10.53.0.2;
	transfer-source 10.53.0.2;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.2; };
	listen-on-v6 { none; };
	recursion no;
	notify yes;
};

key rndc_key {
	secret "1234abcd8765";
	algorithm @DEFAULT_HMAC@;
};

controls {
	inet 10.53.0.2 port @CONTROLPORT@ allow { any; } keys { rndc_key; };
};

zone "example" {
	type primary;
	file "example.db";
};

zone "1st" {
	type primary;
	file "1st.db";
};

zone "2nd" {
	type primary;
	file "2nd.db";
};

zone "xxx" {
	type primary;
	file "xxx.db";
};
