$TTL 300	; 5 minutes
@			IN SOA	mname1. . (
				2000042407 ; serial
				20         ; refresh (20 seconds)
				20         ; retry (20 seconds)
				1814400    ; expire (3 weeks)
				3600       ; minimum (1 hour)
				)
1st.                    NS      ns2.2nd.
1st.                    NS      ns3.2nd.
1st.                    NS      ns5.xxx.
ns2.1st.		A	10.53.0.2
ns3.1st.		A	10.53.0.3
ns4.1st.		A	10.53.0.4
