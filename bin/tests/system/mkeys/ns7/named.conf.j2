// NS7

options {
	query-source address 10.53.0.7;
	notify-source 10.53.0.7;
	transfer-source 10.53.0.7;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.7; };
	listen-on-v6 { none; };
	recursion yes;
	notify no;
	dnssec-validation auto;
};

key rndc_key {
	secret "1234abcd8765";
	algorithm @DEFAULT_HMAC@;
};

controls {
	inet 10.53.0.7 port @CONTROLPORT@ allow { any; } keys { rndc_key; };
};

view view1 {
	zone "." {
		type hint;
		file "../../_common/root.hint";
	};
};

view view2 {
	zone "." {
		type hint;
		file "../../_common/root.hint";
	};
};
