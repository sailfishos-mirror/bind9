$TTL 300
$ORIGIN @fqdn@

@fqdn@		IN		SOA  mname1. . (
				1       ; serial
				20      ; refresh (20 seconds)
				20      ; retry (20 seconds)
				1814400 ; expire (3 weeks)
				3600    ; minimum (1 hour)
				)

				NS	ns2

ns2				A	10.53.0.2
ns3				A	10.53.0.3

scanner				A	10.53.0.2

*._dsync			DSYNC	CDS NOTIFY @PORT@ scanner

{% for dnskey in dnskeys %}
@dnskey@
{% endfor %}

{% for zone in delegations %}
{% set ns_name = zone.ns.name + "." + zone.name %}
@zone.name@.		NS	@ns_name@.
@ns_name@.		A	@zone.ns.ip@
{% endfor %}
