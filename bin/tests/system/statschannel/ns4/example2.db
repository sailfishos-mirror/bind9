$ORIGIN .
$TTL 300	; 5 minutes
example2			IN SOA	mname1. . (
				1          ; serial
				20         ; refresh (20 seconds)
				20         ; retry (20 seconds)
				1814400    ; expire (3 weeks)
				3600       ; minimum (1 hour)
				)
example2.		NS	ns4.example2.
ns4.example2.		A	10.53.0.4

$ORIGIN example2.
a			A	10.0.0.1

latency			NS	ns5.example2.
ns5.example2.		A	10.53.0.5
