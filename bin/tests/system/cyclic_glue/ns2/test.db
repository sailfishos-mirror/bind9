$TTL 300	; 5 minutes
@			IN SOA	mname1. . (
				2000042407 ; serial
				20         ; refresh (20 seconds)
				20         ; retry (20 seconds)
				1814400    ; expire (3 weeks)
				3600       ; minimum (1 hour)
				)
			NS	ns
ns			A	10.53.0.2

foo			NS 	ns.bar
ns.foo			A	10.53.0.3

bar			NS	ns.foo
ns.bar			A	10.53.0.3
