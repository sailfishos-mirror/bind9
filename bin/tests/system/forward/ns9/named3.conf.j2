options {
	query-source address 10.53.0.9;
	notify-source 10.53.0.9;
	transfer-source 10.53.0.9;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.9; };
	listen-on-v6 { none; };
	dnssec-validation no;
	edns-udp-size 1232;
	forward only;
	forwarders { 10.53.0.10; };
};

key rndc_key {
	secret "1234abcd8765";
	algorithm @DEFAULT_HMAC@;
};

controls {
	inet 10.53.0.9 port @CONTROLPORT@ allow { any; } keys { rndc_key; };
};

server 10.53.0.10 {
	edns no;
};

zone "." {
	type hint;
	file "root.db";
};

zone "local.net." {
	type primary;
	file "local.net.db";
	forwarders {};
};
