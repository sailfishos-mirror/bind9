{% set allownewzones = allownewzones | default(True) %}

key rndc_key {
	secret "1234abcd8765";
	algorithm @DEFAULT_HMAC@;
};

controls {
	inet 10.53.0.1 port @CONTROLPORT@ allow { any; } keys { rndc_key; };
};

options {
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.1; };
	listen-on-v6 { none; };
	allow-transfer { any; };
	allow-query { any; };
{% if allownewzones %}
	allow-new-zones yes;
{% else %}
	allow-new-zones no;
{% endif %}
	recursion no;
	dnssec-validation no;
};

zone "." {
	type hint;
	file "../../_common/root.hint";
};

zone "inlinesec.example" {
	type primary;
	file "inlinesec.db";
};

zone "." {
	type redirect;
	file "redirect.db";
};
