include "../../_common/rndc.key";

controls {
	inet 10.53.0.3 port @CONTROLPORT@ allow { any; } keys { rndc_key; };
};

options {
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.3; };
	listen-on-v6 { none; };
	allow-query { any; };
	allow-transfer { any; };
	recursion no;
	allow-new-zones yes;
	dnssec-validation no;
};
