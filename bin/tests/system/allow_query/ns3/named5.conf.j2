options {
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.3; 10.53.1.2; };
	listen-on-v6 { none; };
	recursion no;
	allow-recursion { none; };
	dnssec-validation no;
};

key rndc_key {
	secret "1234abcd8765";
	algorithm @DEFAULT_HMAC@;
};

controls {
	inet 10.53.0.3 port @CONTROLPORT@ allow { any; } keys { rndc_key; };
};

view internal {
        match-destinations { 10.53.0.3; };
        zone "." {
                type hint;
                file "../../_common/root.hint";
        };

        recursion yes;
        allow-recursion { any; };
};
