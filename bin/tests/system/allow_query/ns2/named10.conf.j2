key one {
	algorithm @DEFAULT_HMAC@;
	secret "1234abcd8765";
};

options {
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.2; };
	listen-on-v6 { none; };
	recursion no;
	allow-query { key one; };
	dnssec-validation no;
};

include "controls.conf";

zone "." {
	type hint;
	file "../../_common/root.hint";
};

zone "normal.example" {
	type primary;
	file "generic.db";
};
