options {
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.2; };
	listen-on-v6 { none; };
	recursion no;
	dnssec-validation no;
};

include "controls.conf";

view "internal" {
	allow-query-on { any; };

	zone "." {
		type hint;
		file "../../_common/root.hint";
	};

	zone "normal.example" {
		type primary;
		file "generic.db";
	};

	zone "aclnotallow.example" {
		type primary;
		file "generic.db";
		allow-query-on { none; };
	};
};
