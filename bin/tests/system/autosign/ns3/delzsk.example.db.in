$TTL 300	; 5 minutes
@			IN SOA	mname1. . (
				2000010101 ; serial
				20         ; refresh (20 seconds)
				20         ; retry (20 seconds)
				1814400    ; expire (3 weeks)
				3600       ; minimum (1 hour)
				)
			NS	ns
ns			A	10.53.0.3

sub			NS	ns.sub
			DS	12345 8 1 0000000000000000000000000000000000000000
ns.sub			A	10.53.0.3
