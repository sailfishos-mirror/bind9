$TTL 300

@	IN	SOA	localhost.rpz-external.local root.rpz-external.local. (
	2020022500	; serial number
	60			; refresh every minute
	60			; retry every minute
	432000		; expire in 5 days
	60			; negative caching ttl, 1 minute
)


                IN	NS	LOCALHOST.

allowed       IN	CNAME	.
*.allowed     IN	CNAME	.
