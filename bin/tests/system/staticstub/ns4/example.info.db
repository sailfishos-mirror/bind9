$ORIGIN .
$TTL 300	; 5 minutes
example.info		IN SOA	ns.example.info. hostmaster.example.info. (
				2010080902 ; serial
				20         ; refresh (20 seconds)
				20         ; retry (20 seconds)
				1814400    ; expire (3 weeks)
				3600       ; minimum (1 hour)
				)
example.info.		NS	ns.example.info.
ns.example.info.	A	10.53.0.4

data.example.info.	TXT	"example info data"
