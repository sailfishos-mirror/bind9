$TTL 300        ; 5 minutes
@                       IN SOA  mname1. . (
                                2010062400 ; serial
                                20         ; refresh (20 seconds)
                                20         ; retry (20 seconds)
                                1814400    ; expire (3 weeks)
                                3600       ; minimum (1 hour)
                                )
@                       IN NS   ns6
ns6			IN A	10.53.0.6
a			IN A	1.2.3.4
