$TTL 300	; 5 minutes
@			IN SOA	ns2.example. . (
				2010042407 ; serial
				20         ; refresh (20 seconds)
				20         ; retry (20 seconds)
				1814400    ; expire (3 weeks)
				3600       ; minimum (1 hour)
				)
			NS	ns2.example.
			NS	ns3.example.
			A	10.53.0.1
ns2			A	10.53.0.2
ns3			A	10.53.0.3
