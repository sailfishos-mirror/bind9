$TTL 300
@			IN	SOA  secondary.example. hostmaster.example. (
				1       ; serial
				20      ; refresh (20 seconds)
				20      ; retry (20 seconds)
				1814400 ; expire (3 weeks)
				3600    ; minimum (1 hour)
				)

				NS	ns2
				NS	ns4
				NS	ns6
ns2				A	10.53.0.2
ns4				A	10.53.0.4
ns6				A	10.53.0.6

$ORIGIN explicit.dspublish.ns2-4-6.
bad				NS	ns9.bad
ns9.bad				A	10.53.0.9

$ORIGIN yes.dspublish.ns2-4-6.
bad				NS	ns9.bad
ns9.bad				A	10.53.0.9
